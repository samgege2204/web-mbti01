# ==========================================
# 深渊回响 - 支付宝支付配置
# 复制此文件为 .env 并填入真实参数
# ==========================================

# 服务器端口
PORT=3000

# 服务器基础URL（用于支付宝回调）
# 本地测试: http://localhost:3000
# 生产环境: https://你的域名
BASE_URL=http://localhost:3000

# 支付宝应用ID（从支付宝开放平台获取）
ALIPAY_APP_ID=你的AppID

# 应用私钥（从支付宝开放平台 -> 应用详情 -> 开发设置 -> 接口加签方式 -> 获取）
# 注意：私钥必须包含 -----BEGIN RSA PRIVATE KEY----- 开头和结尾
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n你的私钥内容\n-----END RSA PRIVATE KEY-----"

# 支付宝公钥（从支付宝开放平台获取，不是应用公钥！）
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n支付宝公钥内容\n-----END PUBLIC KEY-----"

# 支付宝网关
# 沙箱环境（测试用）: https://openapi.alipaydev.com/gateway.do
# 生产环境（正式用）: https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipaydev.com/gateway.do

# 签名类型（默认 RSA2，推荐）
ALIPAY_SIGN_TYPE=RSA2
